# ── Ollama ─────────────────────────────────
OLLAMA_MODEL=minimax-m3:cloud
OLLAMA_BASE_URL=http://localhost:11434

# ── Paths ───────────────────────────────────
DATA_OUTPUTS_PATH=data/outputs

# ── News: horários de envio (24h) ──────────
NEWS_SCHEDULE_MORNING=08:00
NEWS_SCHEDULE_NOON=12:00
NEWS_SCHEDULE_AFTERNOON=18:00
NEWS_SCHEDULE_NIGHT=21:00

# ── Flags ───────────────────────────────────
SAVE_OUTPUTS=true

# ── Flask ───────────────────────────────────
FLASK_DEBUG=0
FLASK_SECRET_KEY=cole_um_valor_aleatorio_longo_aqui

# ── APIs externas ───────────────────────────
# Cadastre-se grátis em https://openweathermap.org/api (free tier: 60 req/min)
OPENWEATHER_API_KEY=coloque_sua_chave_aqui

# API-Football (https://www.api-football.com) — free tier 100 req/dia
# Cobre Brasileirão, Carioca, Libertadores, Premier League, NBA, etc.
FOOTBALL_API_KEY=

# Mapbox Directions (https://account.mapbox.com) — free tier 100k req/mês
# Cobre rotas, trânsito em tempo real, direções passo-a-passo.
MAPBOX_API_KEY=

# Endereços favoritos (para o tool de rotas). Formato: nome|endereço;nome|endereço
# Exemplo: Trabalho|R. do Ouvidor, 50, Centro; Casa|R. Voluntários da Pátria, 100, Botafogo
FAVORITE_DESTINATIONS=Trabalho|R. do Ouvidor, 50, Centro; Casa|Av. Atlântica, 1702, Copacabana
